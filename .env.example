# Copy to .env on the box. Keep .env under /home so it survives JarvisLabs pause/resume.

# --- credentials ---
HF_TOKEN=
JL_API_KEY=                       # JarvisLabs (jl CLI / SDK)
CLAUDE_CODE_OAUTH_TOKEN=          # subscription auth for the headless evo agent
ANTHROPIC_API_KEY=                # leave EMPTY when using OAuth above

# --- target model (defaults the discover-built benchmark MAY use; discover decides) ---
SARVAM_MODEL_PATH=sarvamai/sarvam-30b   # HF id or a local snapshot dir under $HF_HOME
SARVAM_QUANT=fp8                  # fp8 (Hopper) | none(bf16) | int8 ; discover chooses what to measure
SARVAM_MAX_MODEL_LEN=8192         # default model-len cap; discover chooses the workload

# --- engine source (the codebase evo optimizes) ---
VLLM_REPO=https://github.com/vllm-project/vllm.git
VLLM_PR=33942                     # rahul-sarvam: SarvamMoEForCausalLM (fused-MoE + Sarvam routing)
VLLM_BASE=/home/ubuntu/vllm       # baseline editable install (built once, precompiled .so)
VENV=/home/ubuntu/.venv           # venv with vllm; eval scripts activate it

# --- GPU layout ---
SARVAM_NUM_GPUS=1                 # 1x H100; gpu_locked.sh serializes parallel subagents' measurements (no contention = reproducible)
GPU_LEASE_TIMEOUT=1800            # seconds a measurement waits for the GPU lock (1 GPU -> longer queue)

# --- evo source ---
EVO_REPO=https://github.com/evo-hq/evo.git
EVO_REF=main

# --- agent (headless Claude Code) ---
CLAUDE_MODEL=claude-opus-4-8         # Opus 4.8; set 'claude-opus-4-8[1m]' for 1M context
CLAUDE_CODE_EFFORT_LEVEL=max         # maximum reasoning effort
# Optimize driver = PROSE (not the workflow). The run prompt sets
# `evo config set default-orchestrator prose` after discover.

# --- notifications (scripts/notify.sh and the `notify` step alert on each new best) ---
TELEGRAM_BOT_TOKEN=                # @BotFather -> /newbot
TELEGRAM_CHAT_ID=                  # message the bot, read chat.id from /getUpdates (or @userinfobot)
WHATSAPP_PHONE=                    # +country number; pairs with CALLMEBOT_APIKEY (callmebot.com relay)
CALLMEBOT_APIKEY=
